DEMO_MODE=false
ALLOW_PASSWORD_RESET=false

# Storage backend: local | s3 | oss | upyun
STORAGE=local

# Local storage
LOCAL_CDN_DOMAIN=

# Shared upload defaults
MAX_UPLOADS_PER_DAY=50
MAX_FILE_SIZE=104857600
MAX_VIDEO_SIZE=500
OUTPUT_FORMAT=webp
LOGIN_RESTRICTION=false
PER_PAGE=20

# Site / upload validation
SITE_DOMAIN=http://localhost:6767
URL_PREFIX=

# AWS S3 / compatible S3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_ACCESS_KEY_SECRET=
S3_CDN_DOMAIN=
S3_ACL=

# Alibaba OSS
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_CDN_DOMAIN=

# UpYun
UPYUN_BUCKET=
UPYUN_OPERATOR=
UPYUN_PASSWORD=
UPYUN_CDN_DOMAIN=

# SMTP / report notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
ADMIN_EMAILS=
