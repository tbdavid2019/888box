Options -Indexes
RewriteEngine On

# ── robots.txt ────────────────────────────────────────────────
# Serve robots.txt as plain text with 200
<Files "robots.txt">
    ForceType text/plain
    <IfModule mod_headers.c>
        Header set Content-Type "text/plain; charset=utf-8"
        Header set X-Robots-Tag "noindex"
    </IfModule>
</Files>

# ── sitemap.xml → sitemap.php ─────────────────────────────────
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]

# ── Pretty Short Share URLs: /v/{token} & /s/{token} ───────────
RewriteRule ^v/([a-zA-Z0-9_-]+)$ view.php?token=$1 [L,QSA]
RewriteRule ^s/([a-zA-Z0-9_-]+)$ view.php?token=$1 [L,QSA]

# ── .well-known/api-catalog ───────────────────────────────────
# Serve without extension, with correct Content-Type
<Files "api-catalog">
    ForceType application/linkset+json
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "*"
    </IfModule>
</Files>

# ── .well-known/ JSON files ───────────────────────────────────
<FilesMatch "\.(json)$">
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=3600"
    </IfModule>
</FilesMatch>

# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Protect sensitive files ───────────────────────────────────
<FilesMatch "\.(env|db|sqlite|log)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(migrate|migrate_v3)\.php$">
    Require all denied
</FilesMatch>
